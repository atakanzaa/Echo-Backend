# ---- Public host and TLS (Caddy) ----
DOMAIN=api.echojournal.net
ACME_EMAIL=ops@echojournal.net

# ---- Database ----
DB_USER=echo_user
DB_PASS=change_this_with_a_strong_password
DB_NAME=echo_prod

# ---- App security ----
JWT_SECRET=replace_with_minimum_64_characters_random_secret
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# ---- AI provider ----
AI_PROVIDER=gemini
AI_FALLBACK_PROVIDER=openai
GEMINI_API_KEY=replace_with_real_key
OPENAI_API_KEY=
CLAUDE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_TOKEN_INFO_URL=https://oauth2.googleapis.com/tokeninfo

# ---- Email (Resend) ----
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_ENABLED=true
RESEND_FROM_ADDRESS=no-reply@echojournal.net
RESEND_FROM_NAME=Echo Journal
RESEND_REPLY_TO_ADDRESS=support@echojournal.net
RESEND_SUPPORT_ADDRESS=support@echojournal.net

# ---- Storage ----
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/tmp/echo-audio

# ---- R2 backup target ----
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BACKUP_BUCKET=echo-backups
R2_ACCESS_KEY=
R2_SECRET_KEY=

# Optional aliases used by AWS CLI (if preferred instead of R2_* keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
