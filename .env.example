# Echo Backend — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
# cp .env.example .env

# Veritabanı
DATABASE_URL=jdbc:postgresql://localhost:5432/echo_db
DATABASE_USERNAME=echo_user
DATABASE_PASSWORD=GUCLU_SIFRE_BURAYA

# JWT Secret — ZORUNLU, minimum 32 karakter
# Üretmek için: openssl rand -base64 64
JWT_SECRET=BURAYA_MIN_64_KARAKTER_GIZLI_ANAHTAR
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# AI Provider: openai | gemini | claude | ollama
AI_PROVIDER=gemini

# API Anahtarları (sadece kullandığın provider için gerekli)
OPENAI_API_KEY=
GEMINI_API_KEY=GEMINI_API_ANAHTARIN
CLAUDE_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_TOKEN_INFO_URL=https://oauth2.googleapis.com/tokeninfo

# Ollama (self-hosted, opsiyonel)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ANALYSIS_MODEL=llama3.1:8b
OLLAMA_COACH_MODEL=llama3.1:8b

# Storage
# local: images saved on disk (dev/single-VPS). s3: Cloudflare R2 (production).
# Note: audio is never stored — bytes are piped directly to AI in memory.
STORAGE_TYPE=local

# Local image path for community posts (used when STORAGE_TYPE=local)
# Production: use a persistent path outside home, e.g. /opt/echo/uploads/images
# LOCAL_IMAGES_PATH=/opt/echo/uploads/images

# Cloudflare R2 — only required when STORAGE_TYPE=s3
# Endpoint:  https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Public URL: https://pub-<HASH>.r2.dev  (or your custom domain via CF)
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_REGION=auto
R2_IMAGES_BUCKET=
R2_IMAGES_PUBLIC_URL=
